 fn parse_port(hex_addr: &str) -> u16 {
     if let Some(colon_pos) = hex_addr.rfind(':') {
         let port_hex = &hex_addr[colon_pos + 1..];
         if let Ok(port) = u16::from_str_radix(port_hex, 16) {
             return port;
         }
